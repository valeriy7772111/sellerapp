cat > /root/sellerapp/templates/index.html <<'EOF'
{% extends "base.html" %}

{% block title %}🏠 Главная — SellerApp Pro{% endblock %}

{% block content %}
  <!-- ЛОГО -->
  <img id="logoGlow"
       src="{{ url_for('static', filename='logo.svg') }}"
       alt="SellerApp Pro"
       style="width:96px;height:96px;margin:36px auto 10px;display:block;filter:drop-shadow(0 0 12px rgba(0,255,255,0.4));animation:softPulse 3s ease-in-out infinite;" />

  <h1 class="gradient-title">SellerApp Pro</h1>
  <p>Аналитика и управление для Ozon · WB · Я.Маркета</p>

  <!-- КНОПКИ -->
  <div class="main-buttons">
    <button class="main-btn" onclick="goTo('/stocks')">📦 Остатки и продажи</button>
    <button class="main-btn" onclick="goTo('/analytics')">📊 Аналитика</button>
    <button class="main-btn" onclick="goTo('/forecast')">🧠 Прогноз спроса</button>
    <button class="main-btn" onclick="goTo('/sales_forecast')">📈 Продажи</button>
    <button class="main-btn" onclick="goTo('/ads')">💰 Реклама и продвижение</button>
    <button class="main-btn" onclick="goTo('/deliveries')">🚚 Поставки</button>
  </div>

  <!-- СТАТИСТИКА -->
  <div class="stats-card">
    <div class="stat">
      <div class="value">₽ 248 900</div>
      <div class="label">Оборот за 7 дней</div>
    </div>
    <div class="stat">
      <div class="value">312</div>
      <div class="label">Товаров на складе</div>
    </div>
    <div class="stat">
      <div class="value">⭐ 4.8</div>
      <div class="label">Средний рейтинг</div>
    </div>
    <div class="stat">
      <div class="value">42</div>
      <div class="label">Активные заказы</div>
    </div>
  </div>
{% endblock %}

{% block scripts %}
<style>
.gradient-title {
  font-size: 28px;
  font-weight: 800;
  background: linear-gradient(90deg,#00ffd5,#00bfff);
  -webkit-background-clip: text;
  color: transparent;
  text-align: center;
  margin-top: 6px;
}

.main-buttons {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin: 30px auto;
  max-width: 480px;
}

.main-btn {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  color: #fff;
  font-size: 15px;
  padding: 10px 18px;
  border-radius: 10px;
  backdrop-filter: blur(8px);
  transition: all 0.25s ease;
}

.main-btn:hover {
  background: rgba(0,255,255,0.1);
  border-color: rgba(0,255,255,0.4);
  transform: translateY(-2px);
}

.stats-card {
  max-width: 500px;
  margin: 20px auto 100px;
  padding: 16px;
  background: rgba(255,255,255,0.06);
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 6px 20px rgba(0,0,0,0.25);
  backdrop-filter: blur(6px);
}

.stat {
  text-align: center;
  padding: 6px;
}

.stat .value {
  font-size: 20px;
  font-weight: 700;
  color: #00ffd5;
  text-shadow: 0 0 6px rgba(0,255,255,0.5);
}

.stat .label {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  margin-top: 4px;
}

/* Анимация логотипа */
@keyframes softPulse {
  0% {
    transform: scale(1);
    filter: drop-shadow(0 0 12px rgba(0,255,255,0.4));
  }
  50% {
    transform: scale(1.04);
    filter: drop-shadow(0 0 22px rgba(0,255,255,0.8));
  }
  100% {
    transform: scale(1);
    filter: drop-shadow(0 0 12px rgba(0,255,255,0.4));
  }
}
</style>
{% endblock %}
EOF

sudo systemctl restart sellerapp

